memory {MEMORY_SIZE} gb
set_num_threads({THREAD_CPU})
molecule {
{CHARGE} {MULTIPLICITY}
{COORDINATES}
     units angstrom
     no_reorient
     no_com
     symmetry c1
}

set {
    basis         {BASIS_SET}  
    scf_type      df           
    hessian_write on
    guess         sad
   print         1
maxiter       150
geom_maxiter  100 
}
gradient('{METHOD}')

